{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "wc *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "tree *": "allow"
    },
  },
}
